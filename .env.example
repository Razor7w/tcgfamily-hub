# Copia a .env.local y rellena los valores (Next.js carga .env.local en desarrollo).

# MongoDB (obligatorio para la app; ver app/lib/mongodb.ts)
MONGODB_URI=mongodb://localhost:27017/tcgfamily-hub
# Opcional; por defecto: tcgfamily-hub
# MONGODB_DB_NAME=tcgfamily-hub
# Opcional (Vercel/serverless): pool por instancia; por defecto 10. Sube solo si lo necesitas.
# MONGODB_MAX_POOL_SIZE=10

# Google OAuth (NextAuth + provider Google; ver app/auth.ts)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Auth.js / NextAuth v5: secreto para firmar cookies y sesiones
# Generar uno: openssl rand -base64 32
AUTH_SECRET=

# URL canónica de la app (callbacks OAuth). Ejemplo local:
AUTH_URL=http://localhost:3000

# Resend — aviso por email cuando el admin marca "recepcionado en tienda" (retiro del envío físico)
# https://resend.com/api-keys
RESEND_API_KEY=
# Remitente solo para ese aviso (opcional). Tiene prioridad sobre RESEND_FROM.
# Ej.: notificaciones@hub.tcgfamily.cl o "TCG Family <notificaciones@hub.tcgfamily.cl>"
RESEND_FROM_MAIL_PICKUP=
# Remitente genérico Resend (fallback si RESEND_FROM_MAIL_PICKUP está vacío)
RESEND_FROM=
# Si ambos están vacíos, el código usa notificaciones@hub.tcgfamily.cl (dominio debe estar verificado en Resend)
# En local (yarn dev o URL canónica localhost) no se llama a Resend. Para probar envío real: RESEND_SEND_IN_DEV=true

# Opcional: URL pública si difiere de AUTH_URL (enlaces en correos)
# NEXT_PUBLIC_APP_URL=https://tu-dominio.com

# Cloudflare R2 (subida directa desde el navegador con URL firmada)
# CORS del bucket: además de AllowedOrigins/Methods/Headers, incluye ExposeHeaders con ETag.
# Si falta, el navegador oculta ETag y @uppy/aws-s3 muestra error en consola (subida puede quedar rara).
# Ejemplo (ajusta orígenes prod): incluye https://hub.tcgfamily.cl para subidas desde producción.
# [{"AllowedOrigins":["http://localhost:3000","https://hub.tcgfamily.cl"],"AllowedMethods":["GET","PUT","HEAD"],"AllowedHeaders":["content-type","cache-control"],"ExposeHeaders":["ETag"],"MaxAgeSeconds":3600}]
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
# Base pública para construir la URL final. Recomendado: tu dominio/CDN (ej. https://cdn.tu-dominio.com)
# Debe apuntar al bucket/public access o a un Worker/CDN que sirva los objetos.
R2_PUBLIC_BASE_URL=
